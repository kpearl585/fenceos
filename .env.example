# Public app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Sentry Error Tracking
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# PostHog Product Analytics (optional — no-ops if unset)
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Email / notifications
RESEND_API_KEY=your-resend-api-key
SUPPORT_EMAIL=support@fenceestimatepro.com
WAITLIST_NOTIFY_EMAIL=support@fenceestimatepro.com

# AI / third-party APIs
OPENAI_API_KEY=your-openai-api-key
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Anthropic (used by marked survey extraction and eval scripts)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Cron / automation
CRON_SECRET=your-cron-secret

# Optional platform values
VERCEL_URL=

# Smoke tests
SMOKE_BASE_URL=http://127.0.0.1:3000
SMOKE_SESSION_COOKIE=
SMOKE_KEEP_DATA=0
